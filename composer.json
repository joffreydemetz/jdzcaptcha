{
    "name": "jdz/jdzcaptcha",
    "type": "library",
    "description": "JDZ icon Captcha package for PHP",
    "keywords": [
        "JDZ",
        "package",
        "captcha"
    ],
    "homepage": "https://jdzcaptcha.joffreydemetz.com",
    "license": "proprietary",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-gd": "*",
        "jdz/data": "^2.0",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/http-foundation": "^7.4"
    },
    "suggest": {
        "symfony/http-foundation": "Required to use SymfonySession adapter"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Captcha\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Captcha\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --color=always --testdox"
    }
}